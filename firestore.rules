rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE SECURITY MODEL - ACCESO PÚBLICO
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // Regla para roles de administrador: Lectura pública necesaria para lógica de UI
    match /roles_admin/{uid} {
      allow read: if true;
      allow write: if false;
    }

    // Partidos: Lectura pública, escritura solo admin
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();

      // Votos para mejor gol: Solo miembros pueden votar
      match /votes/{userId} {
        allow read: if true;
        allow write: if isOwner(userId);
      }
    }

    // Jugadores: Lectura pública, escritura propia o admin
    match /players/{playerId} {
      allow read: if true;
      allow write: if isOwner(playerId) || isAdmin();
    }

    // Pan y Queso (Drafts): Lectura pública, escritura miembros o admin
    match /drafts/{draftId} {
      allow read: if true;
      allow write: if isSignedIn() || isAdmin();
    }

    // Galería: Lectura pública, escritura solo admin
    match /gallery/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Temporadas: Lectura pública, escritura solo admin
    match /seasons/{seasonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Configuración de la App: Lectura pública, escritura solo admin
    match /app_settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
