/**
 * Fut7Stats Security Rules
 *
 * Core Philosophy: 
 * This ruleset implements an authorization model focused on "Authorization Independence." 
 * It relies on denormalized ownership fields (like `ratingUserId`) to make local authorization 
 * decisions without requiring expensive cross-document lookups (get() calls). This ensures 
 * high performance and scalability for match statistics and player tracking.
 *
 * Data Structure:
 * The data is organized into top-level collections: /teams, /players, /matches, 
 * /matchevents, /playerRatings, and /roles_admin.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /**
     * @description Checks if the request is coming from an authenticated user.
     */
    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description Checks if the provided UID matches the authenticated user's UID.
     */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /**
     * @description Checks if the user is the owner of the existing document.
     */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Collection Rules ---

    /**
     * @description Rules for admin roles. Users can check their own admin status.
     * @path /roles_admin/{userId}
     */
    match /roles_admin/{userId} {
      allow get: if isOwner(userId);
      allow list: if false;
      allow write: if false; // Roles are managed externally or via Firebase Console for security.
    }

    /**
     * @description Rules for the Teams collection. Teams are public for reading.
     */
    match /teams/{teamId} {
      allow get, list: if true;
      allow create, update, delete: if false; 
    }

    /**
     * @description Rules for the Players collection. Player profiles are public.
     */
    match /players/{playerId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for the Matches collection. Match data is public.
     */
    match /matches/{matchId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for individual match events (goals, fouls, etc).
     */
    match /matchevents/{matchEventId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /**
     * @description Rules for player ratings. Users can rate players and manage their own ratings.
     */
    match /playerRatings/{playerRatingId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ratingUserId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.ratingUserId) && request.resource.data.ratingUserId == resource.data.ratingUserId;
      allow delete: if isExistingOwner(resource.data.ratingUserId);
    }

    /**
     * @description Rules for match goal votes.
     */
    match /matches/{matchId}/votes/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }
  }
}