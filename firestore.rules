rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE SECURITY MODEL
     * Reglas optimizadas para acceso público total en lectura y 
     * protección estricta en escritura.
     */
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // 1. CONFIGURACIÓN Y TEMPORADAS (PÚBLICO)
    match /app_settings/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /seasons/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // 2. PARTIDOS Y VOTOS (PÚBLICO / VOTO PROTEGIDO)
    match /matches/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
      
      match /votes/{uid} {
        allow get, list: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
    
    // 3. JUGADORES (PÚBLICO / PERFIL PROTEGIDO)
    match /players/{id} {
      allow get, list: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == id);
    }
    
    // 4. ROLES Y ADMINISTRACIÓN (ADMIN ONLY)
    match /roles_admin/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // 5. GALERÍA (PÚBLICO)
    match /gallery/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    // 6. DRAFTS (MIEMBROS)
    match /drafts/{id} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }
  }
}