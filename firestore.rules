
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- RULES ---
    
    // Players: Everyone can read, only admin can write
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin() || (isSignedIn() && request.auth.uid == playerId);
    }

    // Matches: Everyone can read, only admin can write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
      
      // Votes subcollection
      match /votes/{userId} {
        allow read: if true;
        allow write: if isSignedIn() && request.auth.uid == userId;
      }
    }

    // Admin Roles: Solo lectura para el propio usuario. Creación deshabilitada momentáneamente.
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow create: if false; // Deshabilitado para evitar nuevos admins por el momento
      allow update, delete, list: if false;
    }
  }
}
