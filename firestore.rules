rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE - REGLAS DE PRODUCCIÓN
     * 
     * - Lectura: 100% Pública para todas las colecciones.
     * - Escritura: Restringida a Administradores.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true
      );
    }

    // Colecciones con Acceso Público Total de Lectura
    match /app_settings/{document=**} { allow read: if true; allow write: if isAdmin(); }
    match /seasons/{document=**}      { allow read: if true; allow write: if isAdmin(); }
    match /matches/{document=**}      { allow read: if true; allow write: if isAdmin(); }
    match /players/{document=**}      { allow read: if true; allow write: if isAdmin() || (isSignedIn() && request.auth.uid == document); }
    match /gallery/{document=**}      { allow read: if true; allow write: if isAdmin(); }
    match /roles_admin/{document=**}  { allow read: if isAdmin(); allow write: if false; }

    // Votación de Goles (Público puede leer, solo dueños pueden escribir)
    match /matches/{matchId}/votes/{userId} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId;
    }
  }
}