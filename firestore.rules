rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE SECURITY MODEL
     * Acceso público total en lectura y protección estricta en escritura.
     */
    
    function isAdmin() {
      // Validación ultra-segura para evitar errores de evaluación con auth nulo
      return request.auth != null && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // 1. CONFIGURACIÓN Y TEMPORADAS (LECTURA PÚBLICA)
    match /app_settings/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /seasons/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // 2. PARTIDOS Y VOTOS (LECTURA PÚBLICA)
    match /matches/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Permiso especial para votar (incluso si el partido es público)
    match /matches/{matchId}/votes/{uid} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
    
    // 3. JUGADORES (LECTURA PÚBLICA)
    match /players/{document=**} {
      allow read: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == request.resource.id);
    }
    
    // 4. ADMINISTRACIÓN (ADMIN ONLY)
    match /roles_admin/{document=**} {
      allow read, write: if isAdmin();
    }
    
    // 5. GALERÍA Y DRAFTS (PÚBLICO / MIEMBROS)
    match /gallery/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /drafts/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
