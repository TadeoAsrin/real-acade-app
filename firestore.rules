
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- RULES ---
    
    // Players: Everyone can read, only admin can write
    match /players/{playerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Matches: Everyone can read, only admin can write
    match /matches/{matchId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Admin Roles: Only authenticated users can see their own status
    match /roles_admin/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId;
      allow list, write: if false; // Managed via console or script
    }
  }
}
