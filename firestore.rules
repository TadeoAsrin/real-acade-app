rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE SECURITY MODEL - ACCESO PÚBLICO TOTAL DE LECTURA
     * Se permite que cualquier persona vea los datos (get, list).
     * La escritura (create, update, delete) queda reservada para administradores.
     */

    function isSignedIn() {
      return request.auth != null;
    }

    // Función isAdmin blindada contra usuarios nulos
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // REGLAS DE LECTURA PÚBLICA TOTAL (Atómicas y robustas)
    match /app_settings/{document=**} { allow read: if true; }
    match /seasons/{document=**}      { allow read: if true; }
    match /matches/{document=**}      { allow read: if true; }
    match /players/{document=**}      { allow read: if true; }
    match /roles_admin/{document=**}  { allow read: if true; }
    match /gallery/{document=**}      { allow read: if true; }
    match /drafts/{document=**}       { allow read: if true; }

    // REGLAS DE ESCRITURA PROTEGIDA
    match /app_settings/{id} { allow write: if isAdmin(); }
    match /seasons/{id}      { allow write: if isAdmin(); }
    match /matches/{id} {
      allow write: if isAdmin();
      match /votes/{uid} {
        allow write: if isOwner(uid);
      }
    }
    match /players/{id} {
      allow write: if isOwner(id) || isAdmin();
    }
    match /gallery/{id} {
      allow write: if isAdmin();
    }
    match /drafts/{id} {
      allow write: if isSignedIn();
    }
  }
}