rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * REAL ACADE SECURITY MODEL
     * Estructura consolidada para evitar ambigüedad en el motor de reglas.
     */
    
    function isAdmin() {
      return request.auth != null && (
        request.auth.token.email == 'tadeoasrin@gmail.com' ||
        (exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/roles_admin/$(request.auth.uid)).data.isAdmin == true)
      );
    }

    // REGLAS CONSOLIDADAS POR RUTA
    
    match /app_settings/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /seasons/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /matches/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
      
      match /votes/{uid} {
        allow get, list: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }
    
    match /players/{id} {
      allow get, list: if true;
      allow write: if isAdmin() || (request.auth != null && request.auth.uid == id);
    }
    
    match /roles_admin/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /gallery/{id} {
      allow get, list: if true;
      allow write: if isAdmin();
    }
    
    match /drafts/{id} {
      allow get, list: if true;
      allow write: if request.auth != null;
    }
  }
}
