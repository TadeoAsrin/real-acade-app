
{
  "entities": {
    "Match": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Match",
      "type": "object",
      "description": "Represents a single soccer match.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the match."
        },
        "date": {
          "type": "string",
          "description": "Date and time the match was played.",
          "format": "date-time"
        },
        "teamAScore": {
          "type": "number",
          "description": "The score for team 1."
        },
        "teamBScore": {
          "type": "number",
          "description": "The score for team 2."
        }
      },
      "required": [
        "id",
        "date",
        "teamAScore",
        "teamBScore"
      ]
    },
    "Player": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Player",
      "type": "object",
      "description": "Represents a player in the soccer league.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the player."
        },
        "name": {
          "type": "string",
          "description": "The player's name."
        },
        "email": {
          "type": "string",
          "description": "The player's email address.",
          "format": "email"
        }
      },
      "required": [
        "id",
        "name",
        "email"
      ]
    },
    "AdminRole": {
      "title": "AdminRole",
      "type": "object",
      "properties": {
        "isAdmin": { "type": "boolean" }
      },
      "required": ["isAdmin"]
    },
    "Draft": {
      "title": "Draft",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "date": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "completed"] },
        "captainA": { "type": "object" },
        "captainB": { "type": "object" },
        "availablePlayers": { "type": "array" },
        "teamAPlayers": { "type": "array" },
        "teamBPlayers": { "type": "array" },
        "picks": { "type": "array" }
      },
      "required": ["id", "date", "status", "captainA", "captainB", "availablePlayers", "teamAPlayers", "teamBPlayers", "picks"]
    }
  },
  "auth": {
    "providers": [
      "password",
      "anonymous"
    ]
  },
  "firestore": {
    "structure": [
      {
        "path": "/matches/{matchId}",
        "definition": {
          "entityName": "Match",
          "schema": {
            "$ref": "#/backend/entities/Match"
          },
          "description": "Stores data for each soccer match."
        }
      },
      {
        "path": "/players/{playerId}",
        "definition": {
          "entityName": "Player",
          "schema": {
            "$ref": "#/backend/entities/Player"
          },
          "description": "Stores data for each player."
        }
      },
      {
        "path": "/roles_admin/{uid}",
        "definition": {
          "entityName": "AdminRole",
          "schema": {
            "$ref": "#/backend/entities/AdminRole"
          },
          "description": "Stores administrative roles for users."
        }
      },
      {
        "path": "/drafts/{draftId}",
        "definition": {
          "entityName": "Draft",
          "schema": {
            "$ref": "#/backend/entities/Draft"
          },
          "description": "Stores real-time draft data for pan y queso."
        }
      }
    ]
  }
}
