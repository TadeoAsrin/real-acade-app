
{
  "entities": {
    "Player": {
      "title": "Player",
      "description": "Represents a football player in the club.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "avatar": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "player"] }
      },
      "required": ["name", "avatar"]
    },
    "Match": {
      "title": "Match",
      "description": "Represents a football match played by the club.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date-time" },
        "teamAScore": { "type": "number" },
        "teamBScore": { "type": "number" },
        "teamAPlayers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "playerId": { "type": "string" },
              "goals": { "type": "number" },
              "isCaptain": { "type": "boolean" },
              "isMvp": { "type": "boolean" },
              "hasBestGoal": { "type": "boolean" }
            }
          }
        },
        "teamBPlayers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "playerId": { "type": "string" },
              "goals": { "type": "number" },
              "isCaptain": { "type": "boolean" },
              "isMvp": { "type": "boolean" },
              "hasBestGoal": { "type": "boolean" }
            }
          }
        }
      },
      "required": ["date", "teamAScore", "teamBScore"]
    }
  },
  "auth": {
    "providers": ["password", "google.com"]
  },
  "firestore": {
    "/players/{playerId}": {
      "schema": "#/entities/Player",
      "description": "Collection of players."
    },
    "/matches/{matchId}": {
      "schema": "#/entities/Match",
      "description": "Collection of match results."
    },
    "/matches/{matchId}/votes/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "votedPlayerId": { "type": "string" }
        }
      },
      "description": "Votes for the best goal of a match."
    },
    "/roles_admin/{userId}": {
      "schema": {
        "type": "object",
        "properties": {
          "isAdmin": { "type": "boolean" }
        }
      },
      "description": "Collection to define administrative roles."
    }
  }
}
